  "info": {
    "_postman_id": "85f3ce14-a92a-459c-bedb-138028224e76",
    "name": "Triton One Solana RPC API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "Triton's enhanced Solana JSON-RPC interface. Exposes the full Solana JSON-RPC surface plus Triton's custom extensions including getTransactionsForAddress (consolidated address history), the improved getRecentPrioritizationFees percentile-aware priority fees API, and the Whirligig WebSocket transactionSubscribe stream. All calls share the standard Solana JSON-RPC request envelope ({jsonrpc, id, method, params}).\n\n\nContact Support:\n Name: Triton One Support\n Email: support@triton.one",
      "type": "text/plain"
    }
